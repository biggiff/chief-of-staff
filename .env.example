# Neon Postgres connection string (use the pooled connection string from the Neon dashboard)
# Example: postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
# Leave blank to use the zero-setup local PGlite database instead.
DATABASE_URL=

# Optional: enable the real AI Chief of Staff (Anthropic Claude).
# Without this, the chat uses the deterministic rule-based engine.
ANTHROPIC_API_KEY=

# Optional: override the model (defaults to claude-opus-4-8).
# For lower cost/latency try claude-sonnet-4-6 or claude-haiku-4-5.
COS_AI_MODEL=

# Optional: Todoist personal API token (Todoist → Settings → Integrations → Developer).
# Enables pulling your real tasks into the briefing.
TODOIST_API_TOKEN=

# Optional: Google Calendar. OAuth client from Google Cloud Console; refresh token
# is generated by `npm run google:auth`.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Optional: app password gate. When set, every page + API requires this password.
# Leave blank to disable (e.g. local dev). Set it in production to protect a public URL.
APP_PASSWORD=
